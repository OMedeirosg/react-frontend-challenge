# TMDB — REST API v3 (https://developer.themoviedb.org/docs)
# Base opcional; se omitida, o app usa https://api.themoviedb.org/3
# VITE_TMDB_BASE_URL=https://api.themoviedb.org/3

# API Read Access Token (header Authorization: Bearer …)
# Obtenha em https://www.themoviedb.org/settings/api (seção "API Read Access Token")
# Copie este arquivo para .env e cole apenas o JWT (sem o prefixo "Bearer ").
VITE_TMDB_READ_ACCESS_TOKEN=your_jwt_here
